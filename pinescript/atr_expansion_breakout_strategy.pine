//@version=5
strategy("ATR Expansion Breakout", overlay=true, pyramiding=0)
len = input.int(20, "Breakout Length")
atrLen = input.int(14, "ATR Length")
expMult = input.float(1.4, "Expansion Mult")
atrMult = input.float(1.3, "SL ATR Mult")
rr = input.float(2.6, "RR")
atr = ta.atr(atrLen)
hi = ta.highest(high, len)[1]
lo = ta.lowest(low, len)[1]
barRange = high - low
if barRange > atr * expMult and ta.crossover(close, hi)
    strategy.entry("L", strategy.long)
    strategy.exit("LX", "L", stop=close-atr*atrMult, limit=close+atr*atrMult*rr)
if barRange > atr * expMult and ta.crossunder(close, lo)
    strategy.entry("S", strategy.short)
    strategy.exit("SX", "S", stop=close+atr*atrMult, limit=close-atr*atrMult*rr)
