//@version=5
strategy("Previous Day Breakout Strategy", overlay=true, initial_capital=100000, pyramiding=0)

atrPeriod = input.int(14, "ATR Period", minval=1)
atrSLMult = input.float(1.2, "ATR SL Multiplier", step=0.1)
rrMultiple = input.float(2.5, "Risk Reward Multiple", step=0.1)
useLongs = input.bool(true, "Enable Longs")
useShorts = input.bool(true, "Enable Shorts")

prevDayHigh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
prevDayLow = request.security(syminfo.tickerid, "D", low[1], lookahead=barmerge.lookahead_on)
prevDayClose = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)

atr = ta.atr(atrPeriod)

longCondition = useLongs and close > prevDayHigh and close[1] <= prevDayHigh
shortCondition = useShorts and close < prevDayLow and close[1] >= prevDayLow

if (longCondition and strategy.position_size <= 0)
    strategy.entry("Long", strategy.long)

if (shortCondition and strategy.position_size >= 0)
    strategy.entry("Short", strategy.short)

if (strategy.position_size > 0)
    longStop = math.max(prevDayLow, strategy.position_avg_price - atr * atrSLMult)
    longRisk = strategy.position_avg_price - longStop
    longTarget = strategy.position_avg_price + longRisk * rrMultiple
    strategy.exit("Long Exit", from_entry="Long", stop=longStop, limit=longTarget)

if (strategy.position_size < 0)
    shortStop = math.min(prevDayHigh, strategy.position_avg_price + atr * atrSLMult)
    shortRisk = shortStop - strategy.position_avg_price
    shortTarget = strategy.position_avg_price - shortRisk * rrMultiple
    strategy.exit("Short Exit", from_entry="Short", stop=shortStop, limit=shortTarget)

plot(prevDayHigh, "Prev Day High", color=color.green, linewidth=2, style=plot.style_linebr)
plot(prevDayLow, "Prev Day Low", color=color.red, linewidth=2, style=plot.style_linebr)
plot(prevDayClose, "Prev Day Close", color=color.orange, linewidth=1, style=plot.style_linebr)
