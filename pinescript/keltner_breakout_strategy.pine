//@version=5
strategy("Keltner Breakout Strategy", overlay=true, initial_capital=100000, pyramiding=0)

emaLength = input.int(20, "EMA Length", minval=1)
atrLength = input.int(14, "ATR Length", minval=1)
kcMultiplier = input.float(1.5, "Keltner Multiplier", step=0.1)
atrSLMult = input.float(1.3, "ATR SL Multiplier", step=0.1)
rrMultiple = input.float(2.5, "Risk Reward Multiple", step=0.1)
useLongs = input.bool(true, "Enable Longs")
useShorts = input.bool(true, "Enable Shorts")

basis = ta.ema(close, emaLength)
atr = ta.atr(atrLength)
upper = basis + atr * kcMultiplier
lower = basis - atr * kcMultiplier

longCondition = useLongs and close > upper and close[1] <= upper[1]
shortCondition = useShorts and close < lower and close[1] >= lower[1]

if (longCondition and strategy.position_size <= 0)
    strategy.entry("Long", strategy.long)

if (shortCondition and strategy.position_size >= 0)
    strategy.entry("Short", strategy.short)

if (strategy.position_size > 0)
    longStop = math.min(basis, strategy.position_avg_price - atr * atrSLMult)
    longRisk = strategy.position_avg_price - longStop
    longTarget = strategy.position_avg_price + longRisk * rrMultiple
    strategy.exit("Long Exit", from_entry="Long", stop=longStop, limit=longTarget)

if (strategy.position_size < 0)
    shortStop = math.max(basis, strategy.position_avg_price + atr * atrSLMult)
    shortRisk = shortStop - strategy.position_avg_price
    shortTarget = strategy.position_avg_price - shortRisk * rrMultiple
    strategy.exit("Short Exit", from_entry="Short", stop=shortStop, limit=shortTarget)

plot(upper, "Upper KC", color=color.green, linewidth=2)
plot(basis, "Basis", color=color.orange, linewidth=1)
plot(lower, "Lower KC", color=color.red, linewidth=2)
