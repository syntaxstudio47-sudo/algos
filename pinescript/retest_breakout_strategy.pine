//@version=5
strategy("Retest Breakout", overlay=true, pyramiding=0)
len = input.int(20, "Structure Length")
atrLen = input.int(14, "ATR Length")
atrMult = input.float(1.3, "SL ATR Mult")
rr = input.float(2.5, "RR")
res = ta.highest(high, len)[1]
sup = ta.lowest(low, len)[1]
atr = ta.atr(atrLen)
breakoutLong = ta.crossover(close, res)
breakoutShort = ta.crossunder(close, sup)
retestLong = close > res and low <= res and close > open
retestShort = close < sup and high >= sup and close < open
if breakoutLong or retestLong
    strategy.entry("L", strategy.long)
    strategy.exit("LX", "L", stop=close-atr*atrMult, limit=close+atr*atrMult*rr)
if breakoutShort or retestShort
    strategy.entry("S", strategy.short)
    strategy.exit("SX", "S", stop=close+atr*atrMult, limit=close-atr*atrMult*rr)
