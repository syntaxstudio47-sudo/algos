//@version=5
strategy("Weekly High Breakout", overlay=true, pyramiding=0)
len = input.int(10, "Weekly Lookback")
atrLen = input.int(14, "ATR Length")
atrMult = input.float(1.5, "SL ATR Mult")
rr = input.float(3.0, "RR")
atr = ta.atr(atrLen)
wh = ta.highest(high, len * 5)[1]
longCond = ta.crossover(close, wh)
if longCond
    strategy.entry("L", strategy.long)
    strategy.exit("LX", "L", stop=close-atr*atrMult, limit=close+atr*atrMult*rr)
plot(wh, color=color.new(color.green, 0))