//@version=5
strategy("Donchian Breakout Strategy", overlay=true, pyramiding=0)
len = input.int(20, "Donchian Length")
atrLen = input.int(14, "ATR Length")
atrMult = input.float(1.5, "SL ATR Mult")
rr = input.float(3.0, "RR")
upper = ta.highest(high, len)[1]
lower = ta.lowest(low, len)[1]
atr = ta.atr(atrLen)
longCond = ta.crossover(close, upper)
shortCond = ta.crossunder(close, lower)
if longCond
    strategy.entry("L", strategy.long)
    strategy.exit("LX", "L", stop=close-atr*atrMult, limit=close+atr*atrMult*rr)
if shortCond
    strategy.entry("S", strategy.short)
    strategy.exit("SX", "S", stop=close+atr*atrMult, limit=close-atr*atrMult*rr)
plot(upper, color=color.new(color.teal, 0))
plot(lower, color=color.new(color.teal, 0))