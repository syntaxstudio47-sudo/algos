//@version=5
strategy("Momentum Ignition Breakout", overlay=true, pyramiding=0)
len = input.int(25, "Lookback")
atrLen = input.int(14, "ATR Length")
atrMult = input.float(1.3, "SL ATR Mult")
rr = input.float(2.6, "RR")
atr = ta.atr(atrLen)
rangeHigh = ta.highest(high, len)[1]
rangeLow = ta.lowest(low, len)[1]
volBurst = volume > ta.sma(volume, len) * 1.5
longCond = volBurst and ta.crossover(close, rangeHigh)
shortCond = volBurst and ta.crossunder(close, rangeLow)
if longCond
    strategy.entry("L", strategy.long)
    strategy.exit("LX", "L", stop=close-atr*atrMult, limit=close+atr*atrMult*rr)
if shortCond
    strategy.entry("S", strategy.short)
    strategy.exit("SX", "S", stop=close+atr*atrMult, limit=close-atr*atrMult*rr)
