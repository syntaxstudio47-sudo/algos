//@version=5
strategy("NR4 Breakout Strategy", overlay=true, initial_capital=100000, pyramiding=0)

atrLength = input.int(14, "ATR Length", minval=1)
atrSLMult = input.float(1.2, "ATR SL Multiplier", step=0.1)
rrMultiple = input.float(2.5, "Risk Reward Multiple", step=0.1)
useLongs = input.bool(true, "Enable Longs")
useShorts = input.bool(true, "Enable Shorts")

range1 = high[1] - low[1]
range2 = high[2] - low[2]
range3 = high[3] - low[3]
range4 = high[4] - low[4]

isNR4 = range1 < range2 and range1 < range3 and range1 < range4

nr4High = high[1]
nr4Low = low[1]
atr = ta.atr(atrLength)

longCondition = useLongs and isNR4 and close > nr4High and close[1] <= nr4High
shortCondition = useShorts and isNR4 and close < nr4Low and close[1] >= nr4Low

if (longCondition and strategy.position_size <= 0)
    strategy.entry("Long", strategy.long)

if (shortCondition and strategy.position_size >= 0)
    strategy.entry("Short", strategy.short)

if (strategy.position_size > 0)
    longStop = math.min(nr4Low, strategy.position_avg_price - atr * atrSLMult)
    longRisk = strategy.position_avg_price - longStop
    longTarget = strategy.position_avg_price + longRisk * rrMultiple
    strategy.exit("Long Exit", from_entry="Long", stop=longStop, limit=longTarget)

if (strategy.position_size < 0)
    shortStop = math.max(nr4High, strategy.position_avg_price + atr * atrSLMult)
    shortRisk = shortStop - strategy.position_avg_price
    shortTarget = strategy.position_avg_price - shortRisk * rrMultiple
    strategy.exit("Short Exit", from_entry="Short", stop=shortStop, limit=shortTarget)

plot(isNR4 ? nr4High : na, "NR4 High", color=color.green, linewidth=2, style=plot.style_linebr)
plot(isNR4 ? nr4Low : na, "NR4 Low", color=color.red, linewidth=2, style=plot.style_linebr)
