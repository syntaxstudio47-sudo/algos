//@version=5
strategy("Bull Flag Breakout", overlay=true, pyramiding=0)
poleLen = input.int(20, "Pole Length")
flagLen = input.int(12, "Flag Length")
atrLen = input.int(14, "ATR Length")
atrMult = input.float(1.3, "SL ATR Mult")
rr = input.float(2.8, "RR")
atr = ta.atr(atrLen)
poleGain = close[flagLen] - open[poleLen + flagLen - 1]
flagHigh = ta.highest(high, flagLen)[1]
flagLow = ta.lowest(low, flagLen)[1]
longCond = poleGain > atr * 2 and flagLow > close[flagLen] * 0.98 and ta.crossover(close, flagHigh)
if longCond
    strategy.entry("L", strategy.long)
    strategy.exit("LX", "L", stop=close-atr*atrMult, limit=close+atr*atrMult*rr)
plot(flagHigh, color=color.new(color.teal, 0))