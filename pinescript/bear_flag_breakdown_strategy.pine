//@version=5
strategy("Bear Flag Breakdown", overlay=true, pyramiding=0)
poleLen = input.int(20, "Pole Length")
flagLen = input.int(12, "Flag Length")
atrLen = input.int(14, "ATR Length")
atrMult = input.float(1.3, "SL ATR Mult")
rr = input.float(2.8, "RR")
atr = ta.atr(atrLen)
poleDrop = open[poleLen + flagLen - 1] - close[flagLen]
flagHigh = ta.highest(high, flagLen)[1]
flagLow = ta.lowest(low, flagLen)[1]
shortCond = poleDrop > atr * 2 and flagHigh < close[flagLen] * 1.02 and ta.crossunder(close, flagLow)
if shortCond
    strategy.entry("S", strategy.short)
    strategy.exit("SX", "S", stop=close+atr*atrMult, limit=close-atr*atrMult*rr)
plot(flagLow, color=color.new(color.orange, 0))