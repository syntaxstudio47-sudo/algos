//@version=5
strategy("Volatility Squeeze Breakout", overlay=true, pyramiding=0)
bbLen = input.int(20, "BB Length")
bbMult = input.float(2.0, "BB Mult")
kcLen = input.int(20, "KC Length")
kcMult = input.float(1.5, "KC Mult")
atrLen = input.int(14, "ATR Length")
rr = input.float(2.6, "RR")
atr = ta.atr(atrLen)
basis = ta.sma(close, bbLen)
dev = bbMult * ta.stdev(close, bbLen)
upper = basis + dev
lower = basis - dev
kcBasis = ta.ema(close, kcLen)
kcUpper = kcBasis + kcMult * atr
kcLower = kcBasis - kcMult * atr
squeeze = upper < kcUpper and lower > kcLower
releaseLong = squeeze[1] and not squeeze and close > upper
releaseShort = squeeze[1] and not squeeze and close < lower
if releaseLong
    strategy.entry("L", strategy.long)
    strategy.exit("LX", "L", stop=close-atr*1.4, limit=close+atr*1.4*rr)
if releaseShort
    strategy.entry("S", strategy.short)
    strategy.exit("SX", "S", stop=close+atr*1.4, limit=close-atr*1.4*rr)
plot(upper, color=color.new(color.blue, 0))
plot(lower, color=color.new(color.blue, 0))