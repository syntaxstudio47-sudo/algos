//@version=5
strategy("NR7 Breakout Strategy", overlay=true, initial_capital=100000, pyramiding=0)

atrPeriod = input.int(14, "ATR Period", minval=1)
atrSLMult = input.float(1.2, "ATR SL Multiplier", step=0.1)
rrMultiple = input.float(2.5, "Risk Reward Multiple", step=0.1)
useLongs = input.bool(true, "Enable Longs")
useShorts = input.bool(true, "Enable Shorts")

range1 = high[1] - low[1]
range2 = high[2] - low[2]
range3 = high[3] - low[3]
range4 = high[4] - low[4]
range5 = high[5] - low[5]
range6 = high[6] - low[6]
range7 = high[7] - low[7]

isNR7 = range1 < range2 and range1 < range3 and range1 < range4 and range1 < range5 and range1 < range6 and range1 < range7
nr7High = high[1]
nr7Low = low[1]
atr = ta.atr(atrPeriod)

longCondition = useLongs and isNR7 and close > nr7High and close[1] <= nr7High
shortCondition = useShorts and isNR7 and close < nr7Low and close[1] >= nr7Low

if (longCondition and strategy.position_size <= 0)
    strategy.entry("Long", strategy.long)

if (shortCondition and strategy.position_size >= 0)
    strategy.entry("Short", strategy.short)

if (strategy.position_size > 0)
    longStop = math.min(nr7Low, strategy.position_avg_price - atr * atrSLMult)
    longRisk = strategy.position_avg_price - longStop
    longTarget = strategy.position_avg_price + longRisk * rrMultiple
    strategy.exit("Long Exit", from_entry="Long", stop=longStop, limit=longTarget)

if (strategy.position_size < 0)
    shortStop = math.max(nr7High, strategy.position_avg_price + atr * atrSLMult)
    shortRisk = shortStop - strategy.position_avg_price
    shortTarget = strategy.position_avg_price - shortRisk * rrMultiple
    strategy.exit("Short Exit", from_entry="Short", stop=shortStop, limit=shortTarget)

plot(isNR7 ? nr7High : na, "NR7 High", color=color.green, linewidth=2, style=plot.style_linebr)
plot(isNR7 ? nr7Low : na, "NR7 Low", color=color.red, linewidth=2, style=plot.style_linebr)
