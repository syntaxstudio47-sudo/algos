//@version=5
strategy("False Breakout Reclaim", overlay=true, pyramiding=0)
len = input.int(20, "Structure Length")
atrLen = input.int(14, "ATR Length")
atrMult = input.float(1.2, "SL ATR Mult")
rr = input.float(2.2, "RR")
atr = ta.atr(atrLen)
hi = ta.highest(high, len)[1]
lo = ta.lowest(low, len)[1]
falseBreakLong = low < lo and close > lo and close > open
falseBreakShort = high > hi and close < hi and close < open
if falseBreakLong
    strategy.entry("L", strategy.long)
    strategy.exit("LX", "L", stop=close-atr*atrMult, limit=close+atr*atrMult*rr)
if falseBreakShort
    strategy.entry("S", strategy.short)
    strategy.exit("SX", "S", stop=close+atr*atrMult, limit=close-atr*atrMult*rr)
